{
  "name": "Material",
  "type": "object",
  "properties": {
    "nome": {
      "type": "string",
      "description": "Nome do material"
    },
    "categoria": {
      "type": "string",
      "enum": [
        "CAUQ",
        "CONCRETO",
        "SOLO",
        "AGREGADO",
        "LIGANTES",
        "MRAF"
      ],
      "description": "Categoria do material"
    }
  },
  "required": [
    "nome"
  ],
  "rls": {
    "create": {
      "$or": [
        {
          "user_condition": {
            "role": "admin"
          }
        },
        {
          "user_condition": {
            "cargo": {
              "$in": [
                "Coordenadora T\u00e9cnica",
                "Coordenadora Comercial",
                "Estagi\u00e1ria",
                "Encarregado",
                "Auxiliar da Qualidade"
              ]
            }
          }
        }
      ]
    },
    "read": {
      "user_condition": {
        "id": {
          "$exists": true
        }
      }
    },
    "update": {
      "$or": [
        {
          "user_condition": {
            "role": "admin"
          }
        },
        {
          "user_condition": {
            "cargo": {
              "$in": [
                "Coordenadora T\u00e9cnica",
                "Coordenadora Comercial",
                "Estagi\u00e1ria",
                "Encarregado",
                "Auxiliar da Qualidade"
              ]
            }
          }
        }
      ]
    },
    "delete": {
      "$or": [
        {
          "user_condition": {
            "role": "admin"
          }
        },
        {
          "user_condition": {
            "cargo": {
              "$in": [
                "Coordenadora T\u00e9cnica",
                "Coordenadora Comercial",
                "Estagi\u00e1ria",
                "Encarregado",
                "Auxiliar da Qualidade"
              ]
            }
          }
        }
      ]
    }
  }
}